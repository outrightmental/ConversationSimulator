{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Conversation Simulator",
  "version": "0.1.0",
  "identifier": "com.outrightmental.convsim",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://127.0.0.1:7354",
    "beforeDevCommand": "pnpm --filter @convsim/web dev",
    "beforeBuildCommand": "pnpm --filter @convsim/web build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Conversation Simulator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**"]
  }
}
