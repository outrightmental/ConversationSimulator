// Steam InstallScript — Windows x86-64 depot.
//
// Installs the Microsoft WebView2 Evergreen Runtime on first launch via Steam.
// This runs once (keyed with HasRunKey) with the elevated privileges Steam
// provides, so the player never sees a separate UAC prompt.
//
// The WebView2 Evergreen Bootstrapper (MicrosoftEdgeWebView2Setup.exe, ~2 MB)
// is included at the depot root.  The bootstrapper downloads and installs only
// the runtime components needed for the installed architecture — it is not a
// full offline installer.  Internet access is required on first launch when
// WebView2 is not already present on the player's system.
//
// On Windows 11 and most current Windows 10 installs, WebView2 ships with the
// OS and this script is a no-op (HasRunKey causes it to skip on subsequent
// launches regardless).
//
// Alternative considered and rejected: WebView2 Fixed Version (~180 MB per
// depot).  Fixed Version would remove the internet requirement but adds 180 MB
// to every Steam install, which is disproportionate to the 2 MB bootstrapper.
// The Evergreen Bootstrapper approach is the official Microsoft recommendation
// for Steam-distributed Tauri/WebView2 applications.
//
// See publishing/STEAM_DEPOT_CONTENTS.md — Windows depot section for the full
// WebView2 runtime strategy and updater policy.
"InstallScript"
{
    "Run Process"
    {
        // HasRunKey ensures this process runs exactly once per machine.
        // Steam writes this registry key after the script completes; on every
        // subsequent launch (including app updates), the key is found and the
        // Run Process block is skipped entirely.
        "HasRunKey"     "HKEY_LOCAL_MACHINE\\SOFTWARE\\Outright Mental\\Conversation Simulator\\WebView2Bootstrapped"

        // The bootstrapper is shipped at the depot root alongside the app binary.
        // Steam resolves the path relative to the depot install directory.
        "Process 1"     "MicrosoftEdgeWebView2Setup.exe"
        "Command 1"     "/silent /install"

        "Description"   "Installing Microsoft WebView2 Runtime (required by Conversation Simulator)..."

        // "none" type: no Steam overlay progress; the bootstrapper handles its
        // own UI (minimal — a brief spinner, then completes silently).
        "Type"          "none"

        // NoCleanUp "1": do not delete the bootstrapper exe after running.
        // Keeping it in the depot means it is present for future repairs
        // without requiring a re-download.
        "NoCleanUp"     "1"
    }
}
